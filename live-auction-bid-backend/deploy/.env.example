# Copy to deploy/.env for local Docker Compose runs, then fill every TOS value.
# Do NOT commit real AK/SK. deploy/.env is ignored by the project .gitignore pattern `.env`.

AUCTION_STORAGE_PROVIDER=tos
AUCTION_TOS_ENDPOINT=
AUCTION_TOS_REGION=
AUCTION_TOS_BUCKET=
AUCTION_TOS_PUBLIC_BASE_URL=
AUCTION_TOS_USE_SSL=true

# Temporary upload objects live under temp/{bizType}/yyyy/mm in OSS.
# They are marked attached when a lot is saved; otherwise delete is attempted on page leave
# and the backend cleanup worker removes expired temporary objects.
AUCTION_TEMP_ASSET_CLEANUP_INTERVAL=1h

AUCTION_TOS_ACCESS_KEY=
AUCTION_TOS_SECRET_KEY=
