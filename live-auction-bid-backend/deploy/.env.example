# Copy this file to deploy/.env for local Docker Compose runs.
# The default path is fully local and does not require cloud credentials.

AUCTION_STORAGE_PROVIDER=local
AUCTION_LOCAL_STORAGE_DIR=/data/live-auction-assets
AUCTION_LOCAL_STORAGE_BUCKET=local
AUCTION_LOCAL_STORAGE_PUBLIC_BASE_URL=http://localhost:18080/assets

AUCTION_ENV=dev
AUCTION_WS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
AUCTION_WS_ALLOW_MISSING_ORIGIN=true
AUCTION_WS_TICKET_TTL=60s
AUCTION_BID_SYNC_PROJECTION=false
AUCTION_RUNTIME_PROJECTION_SHARDS=16
AUCTION_RUNTIME_PROJECTION_DRAIN_BATCHES=8
AUCTION_RUNTIME_PROJECTION_BACKPRESSURE_PENDING_LIMIT=0
AUCTION_RUNTIME_PROJECTION_BACKPRESSURE_LAG=0s
AUCTION_RUNTIME_PROJECT_LEGACY_STREAMS=false
AUCTION_DB_MAX_OPEN_CONNS=20
AUCTION_DB_MAX_IDLE_CONNS=10
AUCTION_DB_CONN_MAX_LIFETIME=30m
AUCTION_DB_CONN_MAX_IDLE_TIME=2m
AUCTION_REDIS_POOL_SIZE=128
AUCTION_REDIS_MIN_IDLE_CONNS=16

# Optional buyer AI semantic search.
# To enable locally, run docker compose with --profile search and set:
# AUCTION_SEARCH_PROVIDER=pgvector
# AUCTION_SEARCH_PG_DSN=postgres://auction_search:auction_search_dev@pgvector:5432/live_auction_search?sslmode=disable
# AUCTION_EMBEDDING_API_KEY=your_dashscope_key
AUCTION_SEARCH_PROVIDER=
AUCTION_SEARCH_PG_DSN=
AUCTION_SEARCH_SYNC_INTERVAL=5m
AUCTION_SEARCH_SYNC_BATCH_LIMIT=500
AUCTION_SEARCH_HIDDEN_RETENTION=168h
AUCTION_SEARCH_PG_PASSWORD=auction_search_dev
AUCTION_EMBEDDING_PROVIDER=dashscope
AUCTION_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AUCTION_EMBEDDING_MODEL=text-embedding-v4
AUCTION_EMBEDDING_DIMENSIONS=1024
AUCTION_EMBEDDING_BATCH_SIZE=10
AUCTION_EMBEDDING_TIMEOUT=8s
AUCTION_EMBEDDING_API_KEY=

# Optional AI assistant. mock keeps local demos deterministic without an API key.
AUCTION_AI_PROVIDER=mock
AUCTION_AI_BASE_URL=
AUCTION_AI_MODEL=
AUCTION_AI_TIMEOUT=8s
AUCTION_AI_MOCK_ON_FAILURE=true
AUCTION_AI_API_KEY=

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANONYMOUS_ENABLED=true

# Optional production object storage. Set AUCTION_STORAGE_PROVIDER=tos and fill these values.
AUCTION_TOS_ENDPOINT=
AUCTION_TOS_REGION=
AUCTION_TOS_BUCKET=
AUCTION_TOS_PUBLIC_BASE_URL=
AUCTION_TOS_USE_SSL=true
AUCTION_TOS_ACCESS_KEY=
AUCTION_TOS_SECRET_KEY=

# Temporary upload objects live under temp/{bizType}/yyyy/mm.
# They are marked attached when a lot is saved; otherwise the cleanup worker removes expired files.
AUCTION_TEMP_ASSET_CLEANUP_INTERVAL=1h
